TELEGRAM_BOT_TOKEN=
BACKEND_URL=http://127.0.0.1:8000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_IMAGE=gpt-4o
OPENAI_MODEL_IMAGE_FALLBACK=

# Feature flags
ENABLE_PDF_IMAGE_FALLBACK=true
ENABLE_IMAGE_OCR_HINT=true
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
ENABLE_SPLIT_MODE=true
PUSH_TO_IIKO=true
IIKO_IMPORT_MODE=dual

# Limits
MAX_UPLOAD_MB=15
MAX_FILES_PER_MINUTE=10
MAX_FILES_PER_BATCH=10

# Observability
LOG_LEVEL=INFO
LOG_MAX_MB=10
LOG_BACKUP_COUNT=14
ALERTS_ENABLED=true
ALERTS_COOLDOWN_SEC=300
ALERTS_TELEGRAM_CHAT_ID=
METRICS_ENABLED=true

# Webhook (optional)
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_SECRET=

# Queue / storage
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=default
QUEUE_TIMEOUT_SINGLE_SEC=900
QUEUE_TIMEOUT_BATCH_SEC=1500
QUEUE_TIMEOUT_IIKO_SEC=2100
QUEUE_RETRY_SINGLE_MAX=1
QUEUE_RETRY_BATCH_MAX=1
QUEUE_RETRY_IIKO_MAX=2
QUEUE_RETRY_INTERVALS_SEC=30,120,300
QUEUE_RESULT_TTL_SEC=86400
QUEUE_FAILURE_TTL_SEC=604800
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/iiko

# IIKO
IIKO_LOGIN_URL=
IIKO_USERNAME=
IIKO_PASSWORD=
IIKO_HEADLESS=true
IIKO_SERVER_BASE_URL=
IIKO_SERVER_AUTH_PATH=/resto/api/auth
IIKO_SERVER_IMPORT_PATH=/resto/api/documents/import/incomingInvoice
IIKO_SERVER_VERIFY_SSL=false
IIKO_SERVER_DEFAULT_STORE_ID=
IIKO_SERVER_DEFAULT_SUPPLIER_ID=
IIKO_SERVER_DEFAULT_CONCEPTION=
IIKO_SERVER_DEFAULT_STATUS=NEW

# IIKO selectors (UI may change)
IIKO_SELECTORS_USERNAME=input[data-testid='input-login']
IIKO_SELECTORS_PASSWORD=input[data-testid='input-password']
IIKO_SELECTORS_SUBMIT=button[data-testid='button-submit-login']
IIKO_SELECTORS_INVENTORY=div.item-wrapper:has-text('Управление складом')
IIKO_SELECTORS_NEW_ROW=button[data-action='add-row']
IIKO_SELECTORS_SAVE=button[data-action='save']
