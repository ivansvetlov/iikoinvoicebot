TELEGRAM_BOT_TOKEN=
BACKEND_URL=http://127.0.0.1:8000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_IMAGE=
OPENAI_MODEL_IMAGE_FALLBACK=

# Logging / observability
LOG_LEVEL=INFO
LOG_MAX_MB=5
LOG_BACKUP_COUNT=5
LOG_ARCHIVE_AFTER_DAYS=7

# Feature flags
ENABLE_PDF_IMAGE_FALLBACK=true
ENABLE_IMAGE_OCR_HINT=true
ENABLE_FAST_PARSER_FALLBACK=true
FAST_PARSER_MIN_CHARS=120
FAST_PARSER_MIN_ITEMS=2
ENABLE_SPLIT_MODE=true
INVOICE_FLOW_MODE=legacy
INVOICE_FLOW_ENABLE_UNIT_CONVERSION=true
INVOICE_FLOW_ENABLE_CATALOG_MATCH=true
PUSH_TO_IIKO=true
IIKO_IMPORT_FALLBACK_ENABLED=true
IIKO_IMPORT_FORMAT=csv
IIKO_IMPORT_EXPORT_DIR=data/exports/iiko

# Limits
MAX_UPLOAD_MB=15
MAX_FILES_PER_MINUTE=10
MAX_FILES_PER_BATCH=10
STATUS_ACTIVE_HOURS=24
STATUS_STALE_MINUTES=20
STATUS_AUTO_REAP=true
STATUS_PIN_MESSAGE=true

# Webhook (optional)
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_SECRET=

# Queue / storage
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=default
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/iiko

# IIKO
IIKO_TRANSPORT=import_only
IIKO_API_BASE_URL=
IIKO_API_AUTH_PATH=/resto/api/auth
IIKO_API_UPLOAD_PATH=/resto/api/documents/import/incomingInvoice
IIKO_API_TIMEOUT_SEC=30
IIKO_API_VERIFY_TLS=true
IIKO_USERNAME=
IIKO_PASSWORD=
IIKO_AUTORESOLVE_PRODUCTS=true
IIKO_AUTOCREATE_PRODUCTS=false
IIKO_AUTOCREATE_NAME_PREFIX=
IIKO_CATALOG_CACHE_SEC=300
IIKO_AUTOFILL_STORE=true
IIKO_INCOMING_INVOICE_STATUS=NEW
IIKO_DEFAULT_SUPPLIER_ID=
IIKO_VERIFY_UPLOAD=true
IIKO_VERIFY_STOCK_BALANCE=true
IIKO_VERIFY_ATTEMPTS=5
IIKO_VERIFY_DELAY_SEC=1.0
